---
layout: base.njk
---
<article class="h-entry article-content">
  <a class="u-url p-name" href="{{ page.url }}" hidden>{{ title }}</a>
  <a class="p-author h-card" href="https://stefanosello.me/" rel="author" hidden>Stefano Sello</a>

  <header class="article-header">
    <p class="section-label">// {{ title }}</p>
    <p class="article-meta">
      <time class="dt-published" datetime="{{ date | dateIso }}">{{ date | dateReadable }}</time>
      · {{ content | readingTime }} min read
    </p>
  </header>

  <div class="e-content">
    {{ content | safe }}
  </div>

  <p class="article-back"><a href="/articles/">← /articles/</a></p>
</article>
